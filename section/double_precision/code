#include <iostream>
#include <iomanip>

int main()
{
    float num_f = 1/3.;
    double num_d = 1/3.;
    long double num_ld = 1/3.L;

    // Set precision ke 25 digit
    std::cout << std::setprecision(25);

    // Cetak (1/3)^2 untuk tiap tipe
    std::cout << num_f * num_f << std::endl;
    std::cout << num_d * num_d << std::endl;
    std::cout << num_ld * num_ld << std::endl;
}